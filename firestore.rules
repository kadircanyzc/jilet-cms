rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ================= HELPERS ================= */

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /* ================= USERS ================= */

    match /users/{userId} {
      allow create: if
        request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.role == "customer" &&
        request.resource.data.kvkkAccepted == true;

      allow read, update: if isOwner(userId);
      allow delete: if false;
    }

    /* ================= BARBERS ================= */

match /barbers/{barberId} {
  allow read: if true;

  // CREATE: Self-registration (V1)
  allow create: if isOwner(barberId);

  // UPDATE: Owner can update existing fields only (safe for gallery updates)
  allow update: if isOwner(barberId)
    && request.resource.data.keys().hasAll(resource.data.keys());

  // DELETE: Admin only
  allow delete: if isAdmin();
}
    /* ================= EMPLOYEES ================= */

    match /employees/{employeeId} {
      // PUBLIC INFO ONLY (NO SLOTS TRUST)
      allow read: if true;

      // Only admin / CF
      allow create, delete: if isAdmin();

      // UPDATE: Sadece Cloud Function (Admin SDK)
      // employeeUpdateServices, updateEmployeeSlots, etc.
      allow update: if false;
    }

    /* ================= EMPLOYEE PRIVATE ================= */

    match /employee_private/{employeeId} {
      allow read, write: if false;
    }

    /* ================= APPOINTMENTS ================= */

    match /appointments/{appointmentId} {

      // READ - Herkes kendi ilgili randevuları görebilir
      allow read: if true;
      // NOT: Employee client-side filter yapacak (employeeId == myId)

      // CREATE → CF ONLY
      // CREATE → CF ONLY
      allow create: if false;

      // UPDATE → CF ONLY
      // customerCancelAppointment, employeeConfirmAppointment, employeeCompleteAppointment
      allow update: if false;
      allow delete: if isAdmin();
    }

    /* ================= REVIEWS ================= */

    match /reviews/{reviewId} {
      allow read: if true;

      // Create: Auth gerekli (CF eligibility check yapacak ama rules allow etmeli)
      allow create: if isAuth() && isOwner(request.resource.data.userId);

      // Owner OR Admin can update/delete (soft delete for admin)
      allow update, delete: if isAuth() && (isOwner(resource.data.userId) || isAdmin());
    }

    /* ================= DELETION LOGS ================= */

    match /deletionLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    /* ================= FAVORITES ================= */

    match /favorites/{favoriteId} {
      allow read: if true;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAuth() && request.auth.uid == resource.data.userId;
      allow update: if false;
    }

    /* ================= NOTIFICATIONS ================= */

    match /notifications/{notificationId} {
      allow read: if true;
      // NOT: Client recipientId ile filter yapacak

      allow create: if isAuth();
      // Cloud Functions notification oluştururken gerekli

      allow update: if isAuth() && (
        (
          isOwner(resource.data.recipientId)
          && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['read','readAt'])
        )
        || isAdmin()
      );

      allow delete: if isAuth() && isOwner(resource.data.recipientId);
    }

    /* ================= FCM TOKENS (Device-Centric) ================= */

    match /fcm_tokens/{tokenHash} {
      // READ: Nobody reads directly (only via Cloud Functions)
      allow read: if false;

      // CREATE/UPDATE: Only via Cloud Functions (registerFcmToken)
      // Clients call Cloud Function, not Firestore directly
      allow create, update: if false;

      // DELETE: Only via Cloud Functions (invalidateFcmToken)
      allow delete: if false;
    }

    match /fcm_token_audit/{auditId} {
      // Audit log - nobody reads/writes (only Cloud Functions)
      allow read, write: if false;
    }

    /* ================= ADMIN ================= */

    match /admins/{adminId} {
      allow read: if isAuth() && isOwner(adminId);
      allow write: if isAdmin();
    }

    match /pending_auth_requests/{requestId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    match /scheduled_notifications/{id} {
      allow read, write: if isAdmin();
    }

    match /analytics_events/{eventId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    /* ================= ANALYTICS V1 ================= */

    // Raw events - mobile write only (anonymous allowed for analytics)
    match /analytics_events_raw/{eventId} {
      allow create: if true;     // Anyone can write analytics (authenticated or anonymous)
      allow read: if false;       // Nobody reads (only Cloud Functions)
      allow update, delete: if false;
    }

    // Daily aggregates - CMS read only
    match /analytics_daily/{date} {
      allow read: if isAdmin();   // CMS dashboard reads
      allow write: if false;      // Only Cloud Functions write
    }

    // Per-barber aggregates - CMS read only
    match /analytics_barber_daily/{docId} {
      allow read: if isAdmin();   // CMS dashboard reads
      allow write: if false;      // Only Cloud Functions write
    }

    /* ================= DEVICES ================= */
    // Device-based notification tokens
    // Any device can register and update its own document
    match /devices/{deviceId} {
      allow read: if true;        // Any authenticated user can read
      allow create: if true;      // Any device can register (even before auth)
      allow update: if true;      // Device can update its token/role
      allow delete: if false;     // Never delete - preserve notification capability
    }

    /* ================= FCM TOKENS (V1) ================= */
    // Employee FCM tokens for notifications
    // ALL writes via Cloud Functions (Admin SDK) only
    // Client cannot create, update, or delete tokens
    match /fcmtokens/{tokenId} {
      allow read: if false;           // Only Cloud Functions read
      allow create: if false;         // Only Admin SDK creates
      allow update: if false;         // Only Admin SDK updates
      allow delete: if false;         // Never delete (audit trail)
    }
  }
}
